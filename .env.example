# Backend Environment Variables
DEBUG=False
SECRET_KEY=your-secret-key-here-change-this
ALLOWED_HOSTS=localhost,127.0.0.1,your-render-domain.onrender.com

# Database (Render PostgreSQL)
DATABASE_URL=postgresql://username:password@host:port/dbname

# CORS Settings
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://your-render-domain.onrender.com

# Frontend API URL
REACT_APP_API_URL=https://your-render-domain.onrender.com/api
